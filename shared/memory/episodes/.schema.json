{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Episode",
  "description": "Structured episodic memory unit for Blum agents",
  "version": "1.1",
  "type": "object",
  "required": ["id", "agent", "timestamp", "topic", "summary"],
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique episode ID: YYYY-MM-DD-HHMMSS-agentname"
    },
    "agent": {
      "type": "string",
      "description": "Agent who recorded this episode"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when episode was recorded"
    },
    "context_hash": {
      "type": "string",
      "description": "SHA-256 hash of triggering message (first 16 chars) — enables temporal queries"
    },
    "topic": {
      "type": "string",
      "description": "Brief topic label (1-5 words)"
    },
    "summary": {
      "type": "string",
      "description": "What happened in this episode (2-5 sentences)"
    },
    "participants": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Who was involved (agent names, 'yeshua', etc.)"
    },
    "decisions": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Key decisions made during this episode"
    },
    "commitments": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Promises or commitments made"
    },
    "valence": {
      "type": "string",
      "enum": ["positive", "neutral", "negative", "mixed"],
      "description": "Emotional/relational tone of the episode"
    },
    "changes": {
      "type": "array",
      "items": { "type": "string" },
      "description": "What changed as a result (files, configs, relationships)"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Semantic tags for retrieval"
    },
    "related_episodes": {
      "type": "array",
      "items": { "type": "string" },
      "description": "IDs of related episodes (for continuity chains)"
    },
    "cross_references": {
      "type": "array",
      "description": "Reciprocal links to other agents' perspectives on same event",
      "items": {
        "type": "object",
        "required": ["agent", "relationship"],
        "properties": {
          "agent": {
            "type": "string",
            "description": "Other agent involved"
          },
          "episode_id": {
            "type": "string",
            "description": "Their episode ID for same event (if known)"
          },
          "relationship": {
            "type": "string",
            "enum": ["requested-by", "delivered-to", "collaborated-with", "reviewed-by", "assigned-by", "received-from"],
            "description": "Relational direction from this agent's perspective"
          }
        }
      }
    }
  }
}
